# EntraShift web UI — build-time environment.
#
# SECURITY NOTE (org policy): NOTHING sensitive belongs in this file or in any
# front-end env var. Anything prefixed with VITE_ is inlined into the JS bundle
# and is fully visible in the browser / page source. Never put client secrets,
# the master encryption key, OIDC client secrets, or Graph tokens here.
#
# Tenant client secrets and the master key live ONLY in the Cloudflare Worker
# (envelope-encrypted in D1 under a Worker Secret). The UI never sees them.

# Base path for API/auth calls. In production the UI is served by the same
# Worker origin, so the default empty value (same-origin) is correct.
# Only set this when running the UI against a remote Worker during development.
VITE_API_BASE=

# Cosmetic only — shown in the UI footer so engineers know which build/env they
# are looking at. Safe to expose.
VITE_APP_ENV=development

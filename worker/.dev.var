# EntraShift Worker — local secret/vars example for `wrangler dev`.
# Copy to `.dev.vars` (git-ignored) for local development. NEVER commit real values.
#
# In production these two are set out-of-band as Worker Secrets:
#   wrangler secret put MASTER_ENCRYPTION_KEY
#   wrangler secret put OIDC_CLIENT_SECRET
# and NEVER appear in wrangler.jsonc or any committed file.

# --- Secrets (production: `wrangler secret put`) --------------------------------
# 32-byte AES-256 key, base64-encoded. Envelope master key for tenant client secrets
# and temporary provisioning passwords. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_ENCRYPTION_KEY="REPLACE_WITH_BASE64_32_BYTE_KEY"

# UI (MSP-tenant) app-registration client secret for the OIDC auth-code flow.
OIDC_CLIENT_SECRET="REPLACE_WITH_UI_APP_CLIENT_SECRET"

# --- Vars (mirror wrangler.jsonc for local dev) ---------------------------------
ENTRA_TENANT_ID="REPLACE_WITH_MSP_TENANT_ID"
OIDC_CLIENT_ID="REPLACE_WITH_UI_APP_CLIENT_ID"
OIDC_REDIRECT_URI="http://localhost:8787/auth/callback"
ALLOWED_GROUP_ID="REPLACE_WITH_MSP_SECURITY_GROUP_OBJECT_ID"
SESSION_TTL_SECONDS="28800"
MIN_POLL_INTERVAL_SEC="30"
CF_ACCESS_TEAM_DOMAIN="https://REPLACE.cloudflareaccess.com"
CF_ACCESS_AUD="REPLACE_WITH_ACCESS_APP_AUD_TAG"
